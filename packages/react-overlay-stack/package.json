{
	"name": "react-overlay-stack",
	"version": "0.0.0",
	"description": "Type-safe, unstyled overlay manager for React with animation lifecycle and stacking support",
	"author": {
		"name": "abi group GmbH",
		"email": "info@abigroup.io",
		"url": "https://abigroup.io"
	},
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"types": "./dist/index.d.cts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"start:dev": "tsdown --watch",
		"format:check": "prettier --check '{{src,test}/**/*,*}.{{t,j}s{,x},json{,5},md,y{,a}ml}'",
		"format:fix": "prettier --write '{{src,test}/**/*,*}.{{t,j}s{,x},json{,5},md,y{,a}ml}'",
		"lint:check": "eslint '{{src,test}/**/*,*}.{t,j}s{,x}'",
		"lint:fix": "eslint '{{src,test}/**/*,*}.{t,j}s{,x}' --fix",
		"test-unit": "vitest --passWithNoTests --run --coverage --config vitest.config.ts --project='*#unit'",
		"test-unit:watch": "vitest --passWithNoTests --config vitest.config.ts --project='*#unit'",
		"typecheck": "tsc --noEmit"
	},
	"lint-staged": {
		"{{src,test}/**/*,*}.{{t,j}s{,x},json{,5},md,y{,a}ml}": [
			"prettier --write"
		],
		"{{src,test}/**/*,*}.{t,j}s{,x}": [
			"eslint --fix"
		]
	},
	"prettier": "@abinnovision/prettier-config",
	"dependencies": {
		"zustand": "^5.0.0"
	},
	"devDependencies": {
		"@abinnovision/eslint-config-base": "^3.2.2",
		"@abinnovision/eslint-config-react": "^3.1.0",
		"@abinnovision/prettier-config": "^2.1.5",
		"@arethetypeswrong/cli": "^0.18.2",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitest/coverage-v8": "^4.1.1",
		"eslint": "^9.39.4",
		"happy-dom": "^20.8.6",
		"prettier": "^3.8.1",
		"publint": "^0.3.18",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tsdown": "^0.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.1"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	}
}
