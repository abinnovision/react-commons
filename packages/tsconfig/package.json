{
	"name": "@internal/tsconfig",
	"version": "0.0.0",
	"private": true,
	"author": {
		"name": "abi group GmbH",
		"email": "info@abigroup.io",
		"url": "https://abigroup.io"
	},
	"scripts": {
		"format:check": "prettier --check '*.{js,jsx,ts,tsx,json,json5,yml,yaml,md}'",
		"format:fix": "prettier --write '*.{js,jsx,ts,tsx,json,json5,yml,yaml,md}'"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,json5,yml,yaml,md}": [
			"prettier --write"
		]
	},
	"prettier": "@abinnovision/prettier-config",
	"devDependencies": {
		"@tsconfig/node24": "^24.0.4",
		"@tsconfig/strictest": "^2.0.8",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3"
	}
}
