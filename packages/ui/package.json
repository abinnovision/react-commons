{
	"name": "@internal/ui",
	"version": "0.0.0",
	"private": true,
	"author": {
		"name": "abi group GmbH",
		"email": "info@abigroup.io",
		"url": "https://abigroup.io"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"development": "./src/index.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./styles/*": "./src/styles/*.css"
	},
	"scripts": {
		"build": "tsc --build tsconfig.build.json && cpx 'src/**/*.{png,jpg,svg,css}' dist --preserve",
		"format:check": "prettier --check '{src,test}/**/*.{t,j}s{,x}' '*.{json{,5},md,y{,a}ml}'",
		"format:fix": "prettier --write '{src,test}/**/*.{t,j}s{,x}' '*.{json{,5},md,y{,a}ml}'",
		"lint:check": "eslint '{src,test}/**/*.{t,j}s{,x}'",
		"lint:fix": "eslint '{src,test}/**/*.{t,j}s{,x}' --fix",
		"test-unit": "vitest --passWithNoTests --run --coverage --config vitest.config.ts --project='*#unit'",
		"test-unit:watch": "vitest --passWithNoTests --config vitest.config.ts --project='*#unit'"
	},
	"lint-staged": {
		"{src,test}/**/*.{t,j}s{,x}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json{,5},md,y{,a}ml}": "prettier --write"
	},
	"prettier": "@abinnovision/prettier-config",
	"dependencies": {
		"@internal/commons": "workspace:^",
		"@urql/exchange-graphcache": "^9.0.0",
		"@urql/exchange-retry": "^2.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"graphql-sse": "^2.6.0",
		"lucide-react": "^1.0.1",
		"tailwind-merge": "^3.5.0",
		"urql": "^5.0.1"
	},
	"devDependencies": {
		"@abinnovision/eslint-config-base": "^3.2.2",
		"@abinnovision/eslint-config-react": "^3.1.0",
		"@abinnovision/eslint-config-typescript": "^2.2.3",
		"@abinnovision/prettier-config": "^2.1.5",
		"@internal/tsconfig": "workspace:*",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitest/coverage-v8": "^4.1.1",
		"cpx2": "^8.0.0",
		"eslint": "^9.39.4",
		"happy-dom": "^20.8.9",
		"prettier": "^3.8.1",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vitest": "^4.1.1"
	},
	"peerDependencies": {
		"graphql": "^16.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	}
}
