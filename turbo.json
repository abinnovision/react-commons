{
	"$schema": "https://turbo.build/schema.json",
	"ui": "stream",
	"noUpdateNotifier": true,
	"tasks": {
		"fix": {
			"dependsOn": ["format:fix", "lint:fix", "sort:fix"]
		},
		"check": {
			"dependsOn": ["format:check", "lint:check", "sort:check"]
		},
		"format:fix": {},
		"format:check": {},
		"lint:fix": {},
		"lint:check": {},
		"sort:fix": {},
		"sort:check": {},
		"build": {
			"inputs": ["src/**/*"],
			"outputs": ["dist/**/*"]
		},
		"start:dev": {
			"dependsOn": ["^build"],
			"persistent": true,
			"cache": false
		},
		"generate": {
			"inputs": ["src/**", ".env.example"],
			"outputs": ["gen/**", "src/**/*.generated.ts", "src/**/*.gen.ts"],
			"dependsOn": ["^build"]
		},
		"test-unit": {
			"dependsOn": ["^build", "generate"],
			"inputs": ["src/**/*", "test/**/*"]
		},
		"test-integration": {
			"dependsOn": ["^build", "generate"],
			"inputs": ["src/**/*", "test/**/*"]
		},
		"test-e2e": {
			"dependsOn": ["^build", "generate"],
			"inputs": ["src/**/*", "test/**/*"]
		}
	}
}
