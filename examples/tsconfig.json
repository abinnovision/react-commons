{
	"compilerOptions": {
		"lib": ["ES2024", "DOM", "DOM.Iterable", "ESNext"],
		"target": "es2024",
		"module": "nodenext",
		"jsx": "react-jsx",

		"noEmit": true,
		"strict": true,

		"isolatedModules": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*", ".storybook/**/*", "*.ts"]
}
